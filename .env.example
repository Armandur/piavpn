# PIA-credentials (obligatoriska)
PIA_USER=
PIA_PASS=

# Region (kör GET /regions för lista). Default: se_stockholm
PIA_REGION=se_stockholm

# Kryptering: strong (AES-256, default) eller normal (AES-128)
PIA_ENCRYPTION=strong

# Protokoll: udp (default) eller tcp
OPENVPN_PROTOCOL=udp

# Portar på hosten
PROXY_PORT=8888
CONTROL_PORT=8000

TZ=Europe/Stockholm
